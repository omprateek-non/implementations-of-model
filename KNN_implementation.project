      "outputs": [],
      "source": [
        "scores = []\n",
        "for i in range(1,16):\n",
        "    model = KNeighborsRegressor(n_neighbors=i)\n",
        "    model.fit(x_train,y_train)\n",
        "    y_pred = model.predict(x_test)\n",
        "    scores.append(r2_score(y_test,y_pred))"
      ]
    },
